# Copy this file to .env and fill in the values before running docker compose.

# ── VAPID push notification keys ─────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
# Admin API key — any strong random string
SUPER_KEY=

# Fernet key for encrypting RTSP URLs at rest. Leave blank to skip encryption.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=24

# ── Uploads ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=500

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# In production set this to your actual frontend URL.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Asia/Manila

# ── Proxy ─────────────────────────────────────────────────────────────────────
# Set to true if running behind a reverse proxy that sets X-Forwarded-For.
TRUST_PROXY_HEADERS=false

# ── Worker ────────────────────────────────────────────────────────────────────
# How many cameras each worker process handles simultaneously.
CAMERAS_PER_WORKER=16

# Run inference on every Nth frame (1 = every frame).
INFERENCE_EVERY_N=1
